# Copy to .env and adjust values before running Docker:
#   cp .env.example .env

SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL (docker-compose service: db)
POSTGRES_DB=taskpin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (docker-compose service: redis) — used by Django Channels
REDIS_HOST=redis
REDIS_PORT=6379

# Host port mapped to the web container
WEB_PORT=8000
