# Copy to .env and adjust values before running Docker:
#   cp .env.example .env
#
# Local dev (runserver, no Docker): leave POSTGRES_HOST and REDIS_HOST unset
# in your shell so SQLite + in-memory Channels are used. The vars below are
# for docker compose only.

SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL (docker-compose service: db) — omit POSTGRES_HOST for local SQLite
POSTGRES_DB=taskpin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (docker-compose service: redis) — used by Django Channels in Docker
REDIS_HOST=redis
REDIS_PORT=6379
# Force in-memory channel layer on a single Daphne container: CHANNEL_LAYER=memory
# CHANNEL_LAYER=memory
CHANNEL_LAYER=redis

# Host port mapped to the web container
WEB_PORT=8000
